---
import Layout from '../layouts/Layout.astro';
---

<Layout title="周易易学 - 道奎">
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-tao-gold text-center mb-12">周易易学</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- 易经原文 -->
      <a href="/yijing/yuanwen" class="block bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-8 hover:border-tao-gold/50 transition-all gold-glow group">
        <h2 class="text-2xl font-bold text-tao-gold mb-3 group-hover:text-tao-red transition-colors">易经原文</h2>
        <p class="text-tao-light/70">六十四卦全文，卦辞、爻辞逐句解读。</p>
      </a>
      
      <!-- 卦象详解 -->
      <a href="/yijing/guaxiang" class="block bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-8 hover:border-tao-gold/50 transition-all gold-glow group">
        <h2 class="text-2xl font-bold text-tao-gold mb-3 group-hover:text-tao-red transition-colors">卦象详解</h2>
        <p class="text-tao-light/70">每一卦的象、彖、文言详解，深入理解卦意。</p>
      </a>
      
      <!-- 河图洛书 -->
      <a href="/yijing/hetu" class="block bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-8 hover:border-tao-gold/50 transition-all gold-glow group">
        <h2 class="text-2xl font-bold text-tao-gold mb-3 group-hover:text-tao-red transition-colors">河图洛书</h2>
        <p class="text-tao-light/70">天地之数，河出图洛出书，易学之源。</p>
      </a>
      
      <!-- 五行八卦 -->
      <a href="/yijing/wuxing" class="block bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-8 hover:border-tao-gold/50 transition-all gold-glow group">
        <h2 class="text-2xl font-bold text-tao-gold mb-3 group-hover:text-tao-red transition-colors">五行八卦</h2>
        <p class="text-tao-light/70">金木水火土相生相克，八卦方位与象征。</p>
      </a>
    </div>
  </section>
</Layout>
