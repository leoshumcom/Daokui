---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页 - 道奎">
  <!-- Hero 区域：全屏阴阳鱼 -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-cloud-pattern">
    <!-- 背景渐变 -->
    <div class="absolute inset-0 bg-gradient-to-b from-tao-black via-tao-dark/50 to-tao-black"></div>
    
    <!-- 阴阳鱼动画容器 -->
    <div class="relative z-10 flex flex-col items-center justify-center">
      <!-- 太极图 -->
      <div class="animate-taiji-spin">
        <svg width="300" height="300" viewBox="0 0 200 200" class="drop-shadow-2xl">
          <!-- 外圈 -->
          <circle cx="100" cy="100" r="95" fill="none" stroke="#d4a574" stroke-width="3"/>
          <!-- 阴（白） -->
          <path d="M100 5 A95 95 0 0 1 100 195 A47.5 47.5 0 0 0 100 100 A47.5 47.5 0 0 1 100 5" fill="#f5f5dc"/>
          <!-- 阳（黑） -->
          <path d="M100 5 A95 95 0 0 0 100 195 A47.5 47.5 0 0 1 100 100 A47.5 47.5 0 0 0 100 5" fill="#1a1a2e"/>
          <!-- 阴中阳眼 -->
          <circle cx="100" cy="52.5" r="10" fill="#1a1a2e"/>
          <circle cx="100" cy="52.5" r="3" fill="#f5f5dc"/>
          <!-- 阳中阴眼 -->
          <circle cx="100" cy="147.5" r="10" fill="#f5f5dc"/>
          <circle cx="100" cy="147.5" r="3" fill="#1a1a2e"/>
        </svg>
      </div>
      
      <!-- 八卦环绕 -->
      <svg width="500" height="500" viewBox="0 0 400 400" class="absolute">
        <!-- 乾 ☰ 天 -->
        <g class="animate-bagua-breathe" style="animation-delay: 0s">
          <line x1="200" y1="20" x2="200" y2="50" stroke="#d4a574" stroke-width="3"/>
          <line x1="185" y1="20" x2="185" y2="50" stroke="#d4a574" stroke-width="3"/>
          <line x1="215" y1="20" x2="215" y2="50" stroke="#d4a574" stroke-width="3"/>
          <text x="200" y="70" text-anchor="middle" fill="#d4a574" font-size="14">乾</text>
        </g>
        <!-- 坤 ☷ 地 -->
        <g class="animate-bagua-breathe" style="animation-delay: 0.3s">
          <line x1="200" y1="350" x2="200" y2="380" stroke="#d4a574" stroke-width="3"/>
          <line x1="185" y1="350" x2="185" y2="380" stroke="#d4a574" stroke-width="3"/>
          <line x1="215" y1="350" x2="215" y2="380" stroke="#d4a574" stroke-width="3"/>
          <text x="200" y="395" text-anchor="middle" fill="#d4a574" font-size="14">坤</text>
        </g>
        <!-- 震 ☳ 雷 -->
        <g class="animate-bagua-breathe" style="animation-delay: 0.6s">
          <line x1="30" y1="200" x2="60" y2="200" stroke="#d4a574" stroke-width="3"/>
          <line x1="30" y1="185" x2="60" y2="185" stroke="#d4a574" stroke-width="3"/>
          <line x1="30" y1="215" x2="60" y2="215" stroke="#d4a574" stroke-width="3"/>
          <text x="15" y="205" text-anchor="middle" fill="#d4a574" font-size="14">震</text>
        </g>
        <!-- 巽 ☴ 风 -->
        <g class="animate-bagua-breathe" style="animation-delay: 0.9s">
          <line x1="340" y1="200" x2="370" y2="200" stroke="#d4a574" stroke-width="3"/>
          <line x1="340" y1="185" x2="370" y2="185" stroke="#d4a574" stroke-width="3"/>
          <line x1="340" y1="215" x2="370" y2="215" stroke="#d4a574" stroke-width="3"/>
          <text x="385" y="205" text-anchor="middle" fill="#d4a574" font-size="14">巽</text>
        </g>
        <!-- 坎 ☵ 水 -->
        <g class="animate-bagua-breathe" style="animation-delay: 1.2s">
          <line x1="200" y1="100" x2="200" y2="130" stroke="#d4a574" stroke-width="3"/>
          <line x1="185" y1="115" x2="215" y2="115" stroke="#d4a574" stroke-width="3"/>
          <line x1="200" y1="130" x2="200" y2="160" stroke="#d4a574" stroke-width="3"/>
          <text x="200" y="175" text-anchor="middle" fill="#d4a574" font-size="14">坎</text>
        </g>
        <!-- 离 ☲ 火 -->
        <g class="animate-bagua-breathe" style="animation-delay: 1.5s">
          <line x1="200" y1="270" x2="200" y2="300" stroke="#d4a574" stroke-width="3"/>
          <line x1="185" y1="285" x2="215" y2="285" stroke="#d4a574" stroke-width="3"/>
          <line x1="200" y1="300" x2="200" y2="330" stroke="#d4a574" stroke-width="3"/>
          <text x="200" y="345" text-anchor="middle" fill="#d4a574" font-size="14">离</text>
        </g>
        <!-- 艮 ☶ 山 -->
        <g class="animate-bagua-breathe" style="animation-delay: 1.8s">
          <line x1="100" y1="100" x2="100" y2="130" stroke="#d4a574" stroke-width="3"/>
          <line x1="85" y1="115" x2="115" y2="115" stroke="#d4a574" stroke-width="3"/>
          <line x1="85" y1="115" x2="85" y2="145" stroke="#d4a574" stroke-width="3"/>
          <line x1="115" y1="115" x2="115" y2="145" stroke="#d4a574" stroke-width="3"/>
          <text x="75" y="125" text-anchor="middle" fill="#d4a574" font-size="14">艮</text>
        </g>
        <!-- 兑 ☱ 泽 -->
        <g class="animate-bagua-breathe" style="animation-delay: 2.1s">
          <line x1="300" y1="100" x2="300" y2="130" stroke="#d4a574" stroke-width="3"/>
          <line x1="285" y1="115" x2="315" y2="115" stroke="#d4a574" stroke-width="3"/>
          <line x1="285" y1="115" x2="285" y2="145" stroke="#d4a574" stroke-width="3"/>
          <line x1="315" y1="115" x2="315" y2="145" stroke="#d4a574" stroke-width="3"/>
          <text x="325" y="125" text-anchor="middle" fill="#d4a574" font-size="14">兑</text>
        </g>
      </svg>
      
      <!-- 标题 -->
      <h1 class="text-5xl md:text-7xl font-bold text-tao-gold tracking-[0.3em] mt-40 drop-shadow-lg">
        道奎
      </h1>
      <p class="text-xl md:text-2xl text-tao-light/80 mt-4 tracking-widest">
        大道至简 · 衍化至繁
      </p>
      
      <!-- 入口按钮 -->
      <div class="flex gap-6 mt-10">
        <a href="/dao" class="px-8 py-3 bg-tao-red/80 hover:bg-tao-red border border-tao-gold/50 rounded-lg text-tao-white transition-all gold-glow">
          道教文化
        </a>
        <a href="/yijing" class="px-8 py-3 bg-tao-gray/80 hover:bg-tao-gray border border-tao-gold/50 rounded-lg text-tao-white transition-all gold-glow">
          周易易学
        </a>
        <a href="/shushu" class="px-8 py-3 bg-tao-gray/80 hover:bg-tao-gray border border-tao-gold/50 rounded-lg text-tao-white transition-all gold-glow">
          术数占卜
        </a>
      </div>
    </div>
    
    <!-- 滚动提示 -->
    <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-tao-gold/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- 精选内容区 -->
  <section class="max-w-7xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-tao-gold text-center mb-12">精选内容</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- 卡片 1 -->
      <article class="bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-6 card-enter hover:border-tao-gold/50 transition-all gold-glow">
        <h3 class="text-xl font-bold text-tao-gold mb-3">道家思想</h3>
        <p class="text-tao-light/70 text-sm mb-4">老子《道德经》：道可道，非常道。名可名，非常名。</p>
        <a href="/dao/jiaoxue" class="text-tao-cyan hover:text-tao-gold text-sm">阅读更多 →</a>
      </article>
      
      <!-- 卡片 2 -->
      <article class="bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-6 card-enter hover:border-tao-gold/50 transition-all gold-glow" style="animation-delay: 0.2s">
        <h3 class="text-xl font-bold text-tao-gold mb-3">六十四卦</h3>
        <p class="text-tao-light/70 text-sm mb-4">乾为天、坤为地、水火既济、火水未济...</p>
        <a href="/yijing/guaxiang" class="text-tao-cyan hover:text-tao-gold text-sm">阅读更多 →</a>
      </article>
      
      <!-- 卡片 3 -->
      <article class="bg-tao-gray/50 border border-tao-gold/20 rounded-lg p-6 card-enter hover:border-tao-gold/50 transition-all gold-glow" style="animation-delay: 0.4s">
        <h3 class="text-xl font-bold text-tao-gold mb-3">八字入门</h3>
        <p class="text-tao-light/70 text-sm mb-4">天干地支、五行生克、十神关系，从零开始学八字。</p>
        <a href="/shushu/bazi" class="text-tao-cyan hover:text-tao-gold text-sm">阅读更多 →</a>
      </article>
    </div>
  </section>

  <!-- 免责声明 -->
  <section class="max-w-7xl mx-auto px-4 py-8">
    <div class="bg-tao-dark/50 border border-tao-gold/10 rounded-lg p-6 text-center">
      <p class="text-tao-light/50 text-xs">
        ⚠️ 本站内容仅供文化研究与学术交流，占卜命理仅供参考，不构成任何决策依据。
      </p>
    </div>
  </section>
</Layout>
